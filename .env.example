# Discord secret/config
FASTDL_DISCORD_TOKEN=
FASTDL_DISCORD_GUILD_IDS=
FASTDL_DISCORD_AUDIT_CHANNEL_ID=
FASTDL_ENABLE_MESSAGE_UPLOADS=false
FASTDL_APPROVAL_REQUIRED=false
FASTDL_ADMIN_ROLE_IDS=
FASTDL_REQUIRE_ACCESS_RULES=true
FASTDL_ATTACHMENT_DOWNLOAD_TIMEOUT_SECONDS=120
FASTDL_RATE_LIMIT_MAX_REQUESTS=3
FASTDL_RATE_LIMIT_WINDOW_SECONDS=60

# Optional command names
FASTDL_DISCORD_COMMAND_NAME=upload_fastdl
FASTDL_DISCORD_VALIDATE_COMMAND_NAME=validate_fastdl
FASTDL_DISCORD_PENDING_COMMAND_NAME=fastdl_pending
FASTDL_DISCORD_APPROVE_COMMAND_NAME=fastdl_approve
FASTDL_DISCORD_REJECT_COMMAND_NAME=fastdl_reject
FASTDL_DISCORD_UPLOADS_COMMAND_NAME=fastdl_uploads
FASTDL_DISCORD_ROLLBACK_COMMAND_NAME=fastdl_rollback

# Local storage roots
FASTDL_SERVER_ROOT_PATH=./local-server-test
FASTDL_FASTDL_ROOT_PATH=./local-fastdl-test
FASTDL_COMPRESSED_FORMATS=gz
FASTDL_ALLOW_OVERWRITE=false
FASTDL_BACKUP_EXISTING=true
FASTDL_INSTALL_LOCK_TIMEOUT_SECONDS=300

# Optional SFTP publish target for a FastDL web server on another machine.
# The bot still installs locally first, then uploads generated FastDL files
# such as maps/test.bsp.gz to this remote root.
FASTDL_SFTP_ENABLED=false
FASTDL_SFTP_HOST=
FASTDL_SFTP_PORT=22
FASTDL_SFTP_USERNAME=
FASTDL_SFTP_PASSWORD=
FASTDL_SFTP_PRIVATE_KEY_PATH=
FASTDL_SFTP_PRIVATE_KEY_PASSPHRASE=
FASTDL_SFTP_REMOTE_FASTDL_ROOT_PATH=/var/www/fastdl/svencoop
FASTDL_SFTP_KNOWN_HOSTS_PATH=
FASTDL_SFTP_STRICT_HOST_KEY_CHECKING=true
FASTDL_SFTP_CONNECT_TIMEOUT_SECONDS=30

# Per-content Discord access overrides.
# Comma-separated IDs. With FASTDL_REQUIRE_ACCESS_RULES=true, every configured content
# type must have at least one channel ID and one role ID.
FASTDL_MAP_CHANNEL_IDS=
FASTDL_MAP_ROLE_IDS=
FASTDL_PLAYERMODEL_CHANNEL_IDS=
FASTDL_PLAYERMODEL_ROLE_IDS=
FASTDL_SOUNDS_CHANNEL_IDS=
FASTDL_SOUNDS_ROLE_IDS=
FASTDL_SPRITES_CHANNEL_IDS=
FASTDL_SPRITES_ROLE_IDS=
FASTDL_ANGELSCRIPT_MAP_CHANNEL_IDS=
FASTDL_ANGELSCRIPT_MAP_ROLE_IDS=
