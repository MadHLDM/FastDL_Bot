# Discord secret/config
FASTDL_DISCORD_TOKEN=
FASTDL_DISCORD_GUILD_IDS=
FASTDL_DISCORD_AUDIT_CHANNEL_ID=
FASTDL_ENABLE_MESSAGE_UPLOADS=false

# Optional command names
FASTDL_DISCORD_COMMAND_NAME=upload_fastdl
FASTDL_DISCORD_VALIDATE_COMMAND_NAME=validate_fastdl

# Local storage roots
FASTDL_SERVER_ROOT_PATH=./local-server-test
FASTDL_FASTDL_ROOT_PATH=./local-fastdl-test
FASTDL_COMPRESSED_FORMATS=gz
FASTDL_ALLOW_OVERWRITE=false
FASTDL_BACKUP_EXISTING=true

# Per-content Discord access overrides.
# Comma-separated IDs. Leave role IDs empty to allow any user who can use the channel.
FASTDL_MAP_CHANNEL_IDS=
FASTDL_MAP_ROLE_IDS=
FASTDL_PLAYERMODEL_CHANNEL_IDS=
FASTDL_PLAYERMODEL_ROLE_IDS=
FASTDL_SOUNDS_CHANNEL_IDS=
FASTDL_SOUNDS_ROLE_IDS=
FASTDL_SPRITES_CHANNEL_IDS=
FASTDL_SPRITES_ROLE_IDS=
FASTDL_ANGELSCRIPT_MAP_CHANNEL_IDS=
FASTDL_ANGELSCRIPT_MAP_ROLE_IDS=
